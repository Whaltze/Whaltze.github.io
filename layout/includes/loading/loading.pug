if theme.preloader.enable
  case theme.preloader.load_style    
    when 'gear'
      include ./load_style/gear.pug
    when 'ironheart'
      include ./load_style/ironheart.pug
    when 'scarecrow'
      include ./load_style/scarecrow.pug
    when 'triangles'
      include ./load_style/triangles.pug
    when 'wizard'
      include ./load_style/wizard.pug
    when 'image'
      include ./load_style/image.pug
    when 'spincat'
      include ./load_style/spincat.pug
    when 'pokeball'
      include ./load_style/pokeball.pug
    when 'hyperspace'
      include ./load_style/hyperspace.pug
    default
      include ./load_style/default.pug


script.
  (()=>{
    const $loadingBox = document.getElementById('loading-box')
    const $body = document.body
    const preloader = {
      endLoading: () => {
        $body.style.overflow = ''
        $loadingBox.classList.add('loaded')
      },
      initLoading: () => {
        $body.style.overflow = 'hidden'
        $loadingBox.classList.remove('loaded')
      }
    }

    preloader.initLoading()
    window.addEventListener('load',() => { preloader.endLoading() })
    window.addEventListener('load',() => { preloader.endLoading() })
    window.addEventListener('load',() => { preloader.endLoading() })
    // - 导致一直处于加载界面
    setTimeout(function(){preloader.endLoading();}, 5000);
    document.getElementById('loading-box').addEventListener('click',()=> {preloader.endLoading()})

    //- const isPjaxEnabled = #{theme.pjax?.enable ? 'true' : 'false'};
    //- if (!isPjaxEnabled) {
    //-   document.addEventListener('pjax:send', () => preloader.initLoading());
    //-   document.addEventListener('pjax:complete', () => preloader.endLoading());
    //- }
    if (!{theme.pjax && theme.pjax.enable}) {
      document.addEventListener('pjax:send', () => { preloader.initLoading() })
      document.addEventListener('pjax:complete', () => { preloader.endLoading() })
    }

  })()
